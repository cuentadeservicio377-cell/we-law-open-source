{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "We Law Deadline",
  "type": "object",
  "required": ["matter_id", "name", "due_date", "source", "calculation_basis", "timezone", "confidence", "reminder_policy", "risk_level"],
  "properties": {
    "matter_id": { "type": "string", "pattern": "^MAT-[0-9]{3,}$" },
    "name": { "type": "string" },
    "due_date": { "type": "string" },
    "source": { "type": "string" },
    "calculation_basis": { "type": "string" },
    "legal_basis": { "type": "string" },
    "timezone": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "reminder_policy": { "type": "object" },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high"] }
  },
  "additionalProperties": true
}
