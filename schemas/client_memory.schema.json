{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "We Law Client Memory",
  "type": "object",
  "required": ["client_id", "facts", "preferences", "risks", "interaction_history"],
  "properties": {
    "client_id": { "type": "string", "pattern": "^CLI-[0-9]{3,}$" },
    "client_name": { "type": "string" },
    "facts": { "type": "array", "items": { "type": "string" } },
    "preferences": { "type": "array", "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "type": "string" } },
    "matter_ids": { "type": "array", "items": { "type": "string" } },
    "document_notes": { "type": "array", "items": { "type": "string" } },
    "interaction_history": { "type": "array", "items": { "type": "object" } },
    "updated_at": { "type": "string" }
  },
  "additionalProperties": true
}
