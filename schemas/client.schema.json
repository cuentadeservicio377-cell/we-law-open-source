{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "We Law Client",
  "type": "object",
  "required": ["id", "nombre", "estado"],
  "properties": {
    "id": { "type": "string", "pattern": "^CLI-[0-9]{3,}$" },
    "nombre": { "type": "string", "minLength": 1 },
    "empresa": { "type": "string" },
    "rfc": { "type": "string" },
    "contacto": { "type": "string" },
    "telefono": { "type": "string" },
    "email": { "type": "string" },
    "estado": { "type": "string", "enum": ["prospecto", "activo", "inactivo"] },
    "drive_path": { "type": "string" }
  },
  "additionalProperties": true
}
