# Optional live integrations. The public demo runs without these.
HERMES_COMMAND=hermes
HERMES_WELAW_ROOT=/absolute/path/to/we-law-open-source
PAPERCLIP_API_URL=http://127.0.0.1:3100/api
PAPERCLIP_API_KEY=replace-with-local-dev-key
GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=/absolute/path/to/google_token.json
ENABLE_LIVE_PROBES=false
NEXT_PUBLIC_DEMO_MODE=true
