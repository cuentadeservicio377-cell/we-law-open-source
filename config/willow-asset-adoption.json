      {
        "willowRole": "Plazos Judiciales",
        "hermesRole": "deadlines",
        "paperclipWorker": "Plazos",
        "notes": "Controls due dates, reminders, legal deadlines, and escalation state."
      },
      {
        "willowRole": "Finanzas / Cobranza",
        "hermesRole": "collections",
