    "operatingPrinciples": [
      {
        "id": "despacho_legal_owner",
        "summary": "Despacho Legal owns the main matter and specialists report back to it.",
        "targetStory": "Story 1"
      },
      {
        "id": "one_issue_per_action",
        "summary": "Each concrete action becomes a Paperclip issue carrying MAT-NNN in the title.",
        "targetStory": "Story 3"
      },
      {
        "id": "classified_missing_info",
        "summary": "Missing data is classified as para_avanzar, para_firma, or no_bloqueante.",
        "targetStory": "Story 5"
      },
      {
        "id": "dry_run_first_workspace",
        "summary": "Google Workspace bootstrap must support dry-run before writing files or sheets.",
        "targetStory": "Story 8"
      },
      {
        "id": "approval_before_external_effect",
        "summary": "Engagements, documents, packages, payments, closing, and template updates require approval gates.",
        "targetStory": "Story 7"
      }
    ],
    "roles": [
      {
        "willowRole": "Despacho Legal",
        "hermesRole": "master",
        "paperclipWorker": "Despacho Legal",
        "notes": "Central owner, integrator, reviewer, and project manager."
      },
      {
        "willowRole": "Recepcion / Intake",
        "hermesRole": "intake",
        "paperclipWorker": "Recepcionista Juridico",
        "notes": "Creates or reuses client and matter context, then asks only missing operational facts."
      },
      {
        "willowRole": "Documentos",
        "hermesRole": "documents",
        "paperclipWorker": "Documentos Legales",
        "notes": "Drafts, redlines, extracts evidence, tracks corrections, and blocks signature when facts are missing."
      },
      {
        "willowRole": "Litigio",
        "hermesRole": "litigation",
        "paperclipWorker": "Litigio",
